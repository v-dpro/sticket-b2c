// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  phoneNumber  String? @unique
  passwordHash String?
  username     String  @unique
  displayName  String?
  bio          String?
  avatarUrl    String?
  city         String?

  // OAuth providers
  appleId            String?   @unique
  googleId           String?   @unique
  spotifyId          String?   @unique
  spotifyUsername    String?
  spotifyToken       String?
  spotifyRefresh     String?
  spotifyTokenExpiry DateTime?

  // Legacy / optional
  appleMusicId String?

  // Password reset
  resetToken       String?
  resetTokenExpiry DateTime?

  // Email verification (optional MVP)
  emailVerified Boolean @default(false)
  verifyToken   String?

  privacySetting PrivacySetting @default(PUBLIC)

  // Settings (mobile)
  activityVisibility PrivacySetting @default(FRIENDS)
  showInSuggestions  Boolean        @default(true)
  allowTagging       Boolean        @default(true)
  homeCity           String?
  distanceUnit       String         @default("miles") // miles, km

  // Discovery dials
  sameShowRadius  DiscoveryRadius @default(FRIENDS)
  tasteRadius     DiscoveryRadius @default(FOF)
  showInGalleries Boolean         @default(true)

  // Privacy controls (defaults preserve pre-privacy behavior: everything open)
  profileVisibility    PrivacySetting  @default(PUBLIC)
  defaultLogVisibility PrivacySetting  @default(PUBLIC) // PUBLIC | FRIENDS only (API-validated)
  showTimeline         Boolean         @default(true)
  showCollection       Boolean         @default(true)
  showMapCities        Boolean         @default(true)
  allowPartyInvites    AudienceSetting @default(EVERYONE)
  allowMentions        AudienceSetting @default(EVERYONE)
  appearInTasteMatch   Boolean         @default(true)

  // Redesign additions
  xpTotal    Int       @default(0)
  birthday   DateTime?
  ethnicity  String?
  pronouns   String?
  education  String?
  occupation String?
  languages  String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs             UserLog[]
  tickets          UserTicket[]
  photos           LogPhoto[]
  showMedia        ShowMedia[]
  following        Follow[]            @relation("Following")
  followers        Follow[]            @relation("Followers")
  artistFollows    UserArtistFollow[]
  interestedEvents UserInterested[]
  badges           UserBadge[]
  venueRatings     VenueRating[]
  venueTips        VenueTip[]
  tipUpvotes       TipUpvote[]
  seatViews        SeatView[]
  comments         Comment[]
  logTagsGiven     LogTag[]            @relation("LogTagger")
  logTagsReceived  LogTag[]            @relation("LogTagged")
  wasThere         WasThere[]
  presaleAlerts    PresaleAlert[]
  fanclubs         UserFanclub[]
  eventTracking    UserEventTracking[]
  logLikes         LogLike[]
  xpEntries        XpEntry[]
  checkins         UserCheckin[]
  hangMessages     HangMessage[]
  logComparisons   LogComparison[]
  logCoAuthorships LogCoAuthor[]
  hostedParties      Party[]
  partyMemberships   PartyMember[]
  partyAnnouncements PartyAnnouncement[]
  venueQuestions     VenueQuestion[]
  venueAnswers       VenueAnswer[]
  venueAnswerUpvotes VenueAnswerUpvote[]
  setlistConfirms    SetlistConfirm[]
  tourThreads        TourThread[]
  threadMessages     ThreadMessage[]
  threadReports      ThreadReport[]
  partyMessages      PartyMessage[]
  notifications      Notification[]      @relation("NotificationRecipient")
  notificationsActed Notification[]      @relation("NotificationActor")
  pushTokens         PushToken[]
  showReminders      ShowReminder[]
}

enum PrivacySetting {
  PUBLIC
  FRIENDS
  PRIVATE
}

enum AudienceSetting {
  EVERYONE
  FRIENDS
  NOBODY
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Following", fields: [followerId], references: [id])
  following User @relation("Followers", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model Artist {
  id        String   @id @default(cuid())
  name      String
  spotifyId String?  @unique
  imageUrl  String?
  genres    String[]
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events    Event[]
  followers UserArtistFollow[]
  tours     Tour[]
}

model Tour {
  id        String    @id @default(cuid())
  name      String
  year      Int?
  startDate DateTime?
  endDate   DateTime?
  imageUrl  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  artistId String
  artist   Artist @relation(fields: [artistId], references: [id])

  events  Event[]
  threads TourThread[]

  @@unique([artistId, name])
  @@index([artistId])
}

model Venue {
  id        String   @id @default(cuid())
  name      String
  city      String
  state     String?
  country   String
  address   String?
  lat       Float?
  lng       Float?
  capacity  Int?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events    Event[]
  ratings   VenueRating[]
  tips      VenueTip[]
  seatViews SeatView[]
  questions VenueQuestion[]
}

model Event {
  id         String   @id @default(cuid())
  name       String
  date       DateTime
  imageUrl   String?
  source     String?
  externalId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  artistId String
  artist   Artist  @relation(fields: [artistId], references: [id])
  venueId  String
  venue    Venue   @relation(fields: [venueId], references: [id])
  tourId   String?
  tour     Tour?   @relation(fields: [tourId], references: [id])

  logs       UserLog[]
  tickets    UserTicket[]
  interested UserInterested[]
  tracking   UserEventTracking[]
  seatViews  SeatView[]
  userBadges UserBadge[]
  showMedia  ShowMedia[]
  checkins   UserCheckin[]
  hangThread HangThread?
  parties        Party[]
  setlistEntries SetlistEntry[]
  showReminders  ShowReminder[]

  @@unique([artistId, venueId, date])
  @@index([tourId])
}

model UserLog {
  id         String         @id @default(cuid())
  section    String?
  row        String?
  seat       String?
  rating     Float? // legacy 5-star-style rating; untouched by the score system below
  note       String?
  visibility PrivacySetting @default(PUBLIC)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  // Beli-derived comparison score (0-10, one decimal place) + insertion-order
  // rank key used for stable sorting while scores can tie. sharedAt is null
  // for a "log only" entry and set once the user posts it as a memory.
  score     Float?
  scoreRank Float?
  sharedAt  DateTime?

  userId  String
  user    User   @relation(fields: [userId], references: [id])
  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  photos              LogPhoto[]
  comments            Comment[]
  tags                LogTag[]
  wasThere            WasThere[]
  likes               LogLike[]
  xpEntries           XpEntry[]
  comparisons         LogComparison[] @relation("ComparisonLog")
  opponentComparisons LogComparison[] @relation("ComparisonOpponent")
  coAuthors           LogCoAuthor[]

  @@unique([userId, eventId])
}

model LogTag {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  logId String
  log   UserLog @relation(fields: [logId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("LogTagger", fields: [userId], references: [id], onDelete: Cascade)

  taggedUserId String
  taggedUser   User   @relation("LogTagged", fields: [taggedUserId], references: [id], onDelete: Cascade)

  @@unique([logId, taggedUserId])
  @@index([taggedUserId])
}

model LogPhoto {
  id         String         @id @default(cuid())
  photoUrl   String
  mediaKind  String         @default("image") // "image" | "video"
  duration   Int? // video duration in seconds
  thumbUrl   String? // video thumbnail URL
  visibility PrivacySetting @default(PUBLIC)
  isFlagged  Boolean        @default(false)
  createdAt  DateTime       @default(now())

  logId  String
  log    UserLog @relation(fields: [logId], references: [id])
  userId String
  user   User    @relation(fields: [userId], references: [id])
}

model ShowMedia {
  id          String   @id @default(cuid())
  uri         String
  type        String // "photo" | "video"
  uploadedAt  DateTime @default(now())
  storagePath String?

  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventId])
  @@index([uploadedAt])
}

// ============================================
// PRESALE INTEL (from your ERP)
// ============================================

model Presale {
  id String @id @default(cuid())

  // Event info
  artistName String
  tourName   String?
  venueName  String
  venueCity  String
  venueState String?
  eventDate  DateTime

  // Presale details
  presaleType  String // "Verified Fan", "Amex", "Fan Club", etc.
  presaleStart DateTime
  presaleEnd   DateTime?
  onsaleStart  DateTime?

  // Access
  code           String?
  signupUrl      String?
  signupDeadline DateTime?
  ticketUrl      String?

  // Metadata
  source String // "ERP", "Manual", "Community"
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  alerts PresaleAlert[]

  @@unique([artistName, venueName, eventDate, presaleType])
  @@index([artistName])
  @@index([presaleStart])
  @@index([eventDate])
}

model PresaleAlert {
  id        String @id @default(cuid())
  userId    String
  presaleId String

  notifyStart Boolean @default(true)
  notifyCode  Boolean @default(true)

  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  presale Presale @relation(fields: [presaleId], references: [id], onDelete: Cascade)

  @@unique([userId, presaleId])
  @@index([userId])
  @@index([presaleId])
}

// Show-day reminder toggle (plan tab "REMIND ME"): one row per user+event.
// Swept by the notification engine on the morning of the show day.
model ShowReminder {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
}

model UserTicket {
  id String @id @default(cuid())

  section            String?
  row                String?
  seat               String?
  isGeneralAdmission Boolean @default(false)

  barcode         String?
  barcodeFormat   String  @default("UNKNOWN")
  barcodeImageUrl String?

  status TicketStatus @default(KEEPING)
  source TicketSource @default(MANUAL)

  // Phase 2 prep
  askingPrice Float?

  purchasePrice      Float?
  purchaseDate       DateTime?
  confirmationNumber String?
  notes              String?

  sourceEmail String?
  rawEmailId  String?
  pdfUrl      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId  String
  user    User   @relation(fields: [userId], references: [id])
  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId, barcode])
  @@index([userId])
  @@index([eventId])
  @@index([status])
}

enum TicketStatus {
  KEEPING
  SELLING
  SOLD
  TRANSFERRED
}

enum TicketSource {
  EMAIL
  MANUAL
  SCAN
  TRANSFER
}

model UserInterested {
  id           String   @id @default(cuid())
  notifyOnSale Boolean  @default(true)
  createdAt    DateTime @default(now())

  userId  String
  user    User   @relation(fields: [userId], references: [id])
  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}

model UserArtistFollow {
  id        String   @id @default(cuid())
  notify    Boolean  @default(true)
  tier      String   @default("following") // "top-tier", "following", "casual"
  createdAt DateTime @default(now())

  userId   String
  user     User   @relation(fields: [userId], references: [id])
  artistId String
  artist   Artist @relation(fields: [artistId], references: [id])

  @@unique([userId, artistId])
  @@index([userId])
  @@index([tier])
}

// NEW: Fanclub membership tracking (user self-reported)
model UserFanclub {
  id String @id @default(cuid())

  artistId    String
  artistName  String // Denormalized for display
  fanclubName String // "Taylor Nation", "BeyHive", etc.

  isMember    Boolean   @default(false)
  memberSince DateTime?
  renewalDate DateTime?
  cost        Float? // Annual cost if known
  signupUrl   String? // Link to official signup

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, artistId])
  @@index([userId])
  @@index([renewalDate])
}

// NEW: User event tracking status (beyond just "interested")
model UserEventTracking {
  id String @id @default(cuid())

  status   String // "interested", "watching-secondary", "presale-alert", "bought"
  maxPrice Float? // For secondary market alerts
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([userId])
  @@index([status])
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User    @relation(fields: [userId], references: [id])
  logId  String
  log    UserLog @relation(fields: [logId], references: [id])

  parentId String?
  parent   Comment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentThread")
}

model WasThere {
  id     String @id @default(cuid())
  userId String
  logId  String

  user User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  log  UserLog @relation(fields: [logId], references: [id], onDelete: Cascade)

  @@unique([userId, logId])
}

model Badge {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String   @unique
  description String
  category    String
  rarity      String
  icon        String
  points      Int      @default(0)
  iconUrl     String?
  criteria    Json
  createdAt   DateTime @default(now())

  users UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  earnedAt DateTime @default(now())

  userId  String
  user    User    @relation(fields: [userId], references: [id])
  badgeId String
  badge   Badge   @relation(fields: [badgeId], references: [id])
  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([eventId])
}

model VenueRating {
  id         String   @id @default(cuid())
  sound      Int?
  sightlines Int?
  drinks     Int?
  staff      Int?
  access     Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId  String
  user    User   @relation(fields: [userId], references: [id])
  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id])

  @@unique([userId, venueId])
}

model VenueTip {
  id        String   @id @default(cuid())
  text      String
  category  String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId  String
  user    User   @relation(fields: [userId], references: [id])
  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id])

  upvotes TipUpvote[]

  @@index([venueId])
}

model TipUpvote {
  id     String @id @default(cuid())
  userId String
  tipId  String

  user User     @relation(fields: [userId], references: [id])
  tip  VenueTip @relation(fields: [tipId], references: [id])

  @@unique([userId, tipId])
}

model SeatView {
  id           String   @id @default(cuid())
  section      String
  row          String?
  photoUrl     String? // optional: a seat rating can exist without a view photo
  thumbnailUrl String?
  rating       Int? // 1-5, "how's the view from here"
  createdAt    DateTime @default(now())

  userId  String
  user    User    @relation(fields: [userId], references: [id])
  venueId String
  venue   Venue   @relation(fields: [venueId], references: [id])
  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id])
}

// ==================== REDESIGN MODELS ====================

model LogLike {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  logId     String
  log       UserLog  @relation(fields: [logId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, logId])
  @@index([logId])
}

model XpEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  logId     String?
  log       UserLog? @relation(fields: [logId], references: [id], onDelete: SetNull)
  amount    Int
  reason    String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model UserCheckin {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, eventId])
}

model HangThread {
  id        String        @id @default(cuid())
  eventId   String        @unique
  event     Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  messages  HangMessage[]
  createdAt DateTime      @default(now())
}

model HangMessage {
  id        String     @id @default(cuid())
  threadId  String
  thread    HangThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String
  pinned    Boolean    @default(false)
  createdAt DateTime   @default(now())
}

// ==================== SCORING (Beli-style compare-to-rank) ====================

enum ComparisonResult {
  WIN
  LOSS
  TIE
}

// Audit trail of every compare answer a user gives while placing a new log
// into their ranked list. `round` is the 1-indexed sequence number of the
// comparison for a given `logId` (first question asked = round 1).
model LogComparison {
  id        String           @id @default(cuid())
  result    ComparisonResult
  round     Int
  createdAt DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  logId String
  log   UserLog @relation("ComparisonLog", fields: [logId], references: [id], onDelete: Cascade)

  opponentLogId String
  opponentLog   UserLog @relation("ComparisonOpponent", fields: [opponentLogId], references: [id], onDelete: Cascade)

  @@index([logId])
  @@index([opponentLogId])
  @@index([userId])
}

enum CoAuthorStatus {
  INVITED
  ACCEPTED
  DECLINED
}

// Lets a log be jointly credited to friends who were also there (e.g. tagged
// into someone else's memory and asked to co-sign it).
model LogCoAuthor {
  id          String         @id @default(cuid())
  status      CoAuthorStatus @default(INVITED)
  invitedAt   DateTime       @default(now())
  respondedAt DateTime?

  logId String
  log   UserLog @relation(fields: [logId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([logId, userId])
  @@index([userId])
}

// ==================== PARTIES (pre/post-show meetups per event) ====================

enum PartyVisibility {
  PUBLIC
  INVITE
}

// Lifecycle: cancel is soft (CANCELLED) so members still see the party
// struck through instead of it vanishing. DELETE remains a hard purge.
enum PartyStatus {
  ACTIVE
  CANCELLED
}

// Doubles as the member's role: HOST is the creator's member row, COHOST is
// a promoted GOING member with host powers (approve/deny, invite, edit —
// not cancel).
enum PartyMemberStatus {
  HOST
  COHOST
  INVITED
  REQUESTED
  GOING
  DECLINED
}

model Party {
  id          String          @id @default(cuid())
  title       String
  description String?
  location    String?
  startsAt    DateTime?
  visibility  PartyVisibility @default(PUBLIC)
  status      PartyStatus     @default(ACTIVE)
  createdAt   DateTime        @default(now())

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  hostId  String
  host    User   @relation(fields: [hostId], references: [id], onDelete: Cascade)

  members       PartyMember[]
  announcements PartyAnnouncement[]
  chatMessages  PartyMessage[]

  @@index([eventId])
  @@index([hostId])
}

model PartyMember {
  id          String            @id @default(cuid())
  status      PartyMemberStatus
  respondedAt DateTime?
  createdAt   DateTime          @default(now())

  partyId String
  party   Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([partyId, userId])
  @@index([userId])
}

model PartyAnnouncement {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())

  partyId  String
  party    Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([partyId])
}

// ==================== VENUE Q&A ====================

model VenueQuestion {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())

  venueId  String
  venue    Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  answers VenueAnswer[]

  @@index([venueId])
}

model VenueAnswer {
  id        String   @id @default(cuid())
  text      String
  upvotes   Int      @default(0) // denormalized counter, kept in sync with VenueAnswerUpvote rows
  createdAt DateTime @default(now())

  questionId String
  question   VenueQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  authorId   String
  author     User          @relation(fields: [authorId], references: [id], onDelete: Cascade)

  upvoters VenueAnswerUpvote[]

  @@index([questionId])
}

model VenueAnswerUpvote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  answerId String
  answer   VenueAnswer @relation(fields: [answerId], references: [id], onDelete: Cascade)
  userId   String
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([answerId, userId])
}

// ==================== CROWD-SOURCED SETLISTS ====================

enum SetlistVote {
  YES
  NO
}

model SetlistEntry {
  id           String   @id @default(cuid())
  position     Int
  songTitle    String
  confirmCount Int      @default(1) // net crowd confidence: +1 per YES, -1 per NO
  createdAt    DateTime @default(now())

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  confirms SetlistConfirm[]

  @@unique([eventId, position, songTitle])
  @@index([eventId])
}

model SetlistConfirm {
  id        String      @id @default(cuid())
  vote      SetlistVote
  createdAt DateTime    @default(now())

  entryId String
  entry   SetlistEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  userId  String
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entryId, userId])
}

// ==================== DISCOVERY DIALS ====================

enum DiscoveryRadius {
  OFF
  FRIENDS
  FOF
  EVERYONE
}

// ==================== TOUR THREADS (Reddit-lite discussion) ====================
// Flat threads on a tour: a TourThread is the post, ThreadMessages are its
// replies in one flat list (no nesting). Moderation is report-to-flag via
// ThreadReport (thread- or message-scoped).

model TourThread {
  id        String   @id @default(cuid())
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tourId   String
  tour     Tour   @relation(fields: [tourId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  messages ThreadMessage[]
  reports  ThreadReport[]

  @@index([tourId])
}

model ThreadMessage {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())

  threadId String
  thread   TourThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId String
  author   User       @relation(fields: [authorId], references: [id], onDelete: Cascade)

  reports ThreadReport[]

  @@index([threadId])
}

model ThreadReport {
  id        String   @id @default(cuid())
  reason    String?
  createdAt DateTime @default(now())

  threadId   String?
  thread     TourThread?    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  messageId  String?
  message    ThreadMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  reporterId String
  reporter   User           @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

// ==================== PARTY CHAT ====================
// Two-way group chat for a party's members — distinct from the host-only,
// one-way PartyAnnouncement.

model PartyMessage {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())

  partyId  String
  party    Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([partyId])
}

// ==================== NOTIFICATIONS ====================
// In-app notification feed rows (served by GET /notifications) plus the Expo
// push tokens registered by the mobile app (POST /notifications/push-token).
// `type` is a free-form string (mention, comment, like, party_request, ...)
// so new notification kinds don't need a migration.

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)

  // Who triggered it (optional; kept when the actor deletes their account).
  actorId String?
  actor   User?   @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, read])
}

model PushToken {
  id        String   @id @default(cuid())
  token     String   @unique // Expo push token (ExponentPushToken[...])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
